# Copy to .env and fill in values
# For Render: set these in Dashboard → Environment (do not commit .env)

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

DB_HOST=your-host.aivencloud.com
DB_USER=avnadmin
DB_PASSWORD=your-password
DB_NAME=defaultdb
DB_PORT=18933
DB_SSL_ENABLED=true

JWT_SECRET=your-random-secret
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_SECRET=your-cookie-secret

CORS_ORIGINS=http://localhost:3000,https://your-app.onrender.com

ADMIN_DEFAULT_EMAIL=coordinator@gmhsc.ca
ADMIN_DEFAULT_PASSWORD=your-admin-password
